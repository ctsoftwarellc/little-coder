# Copy to .env (git-ignored) and edit. Loaded by bin/little-coder.mjs at launch.
# A real shell environment variable overrides anything set here.

# ── Local model provider (pick the one you serve) ────────────────
# LM Studio:
LMSTUDIO_API_KEY=local
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_MODEL_ID=qwen/qwen3.6-35b-a3b      # also becomes the default model, so `little-coder` needs no arg
# llama.cpp / Ollama equivalents:
# LLAMACPP_API_KEY=noop
# LLAMACPP_BASE_URL=http://127.0.0.1:8888/v1
# OLLAMA_API_KEY=noop

# ── Arcova (Laravel mode) ────────────────────────────────────────
ARCOVA_SAFE_MODE=1
ARCOVA_PHP=C:\path\to\php.exe
ARCOVA_VERIFY_TIMEOUT_MS=45000

# ── Harness features (see docs/harness-design-notes.md) ──────────
LITTLE_CODER_FROZEN_PREFIX=1        # #2 keep KV cache warm
LITTLE_CODER_PLAN_ANCHOR=1          # #7 Plan tool + per-turn re-anchor
LITTLE_CODER_FUZZY_EDIT=1           # #8 forgive whitespace in edits (default on)
LITTLE_CODER_AMBIENT_PHP_LINT=1     # #5 auto php -l after each .php edit (default on)
# LITTLE_CODER_PHASE_GATING=1       # #6 phase-scoped tools (aggressive; off by default)

# ── Narrator UX (separate tiny model) ────────────────────────────
LITTLE_CODER_NARRATOR_BASE_URL=http://127.0.0.1:1234/v1
LITTLE_CODER_NARRATOR_MODEL=google/gemma-4-e2b
LITTLE_CODER_NARRATOR_API_KEY=local
# LITTLE_CODER_NARRATOR=0           # keep live narration, skip the gemma summaries
# LITTLE_CODER_NARRATOR_UI=0        # turn off the narrator widget entirely
